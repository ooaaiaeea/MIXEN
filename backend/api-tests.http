# ============================================================================
# REST CLIENT TEST SUITE
# ============================================================================
# INSTRUCTIONS FOR DEVELOPERS & FUTURE GEMINI SESSIONS:
# 1. Format: This file is parsed by the VS Code "REST Client" extension.
# 2. Separation: Every individual HTTP request MUST be separated by ###
# 3. Variables: Define file-wide variables at the top using: @variableName = value
# 4. Reference: Use variables in URLs/headers/body using: {{variableName}}
# 5. Grouping: Group all tests for a single endpoint under a prominent comment header.
# 6. Test Coverage: Every endpoint MUST have multiple requests testing:
#    - The successful "happy path" (e.g., 200 OK, 201 Created).
#    - Error handling (e.g., 400 Bad Request, 401 Unauthorized, 409 Conflict).
# 7. Naming: Use the `# @name RequestName` syntax before a request to name it,
#    allowing its response to be referenced in subsequent requests if needed.
# ============================================================================

@baseUrl = http://localhost:8000

###

# ============================================================================
# GROUP: General API Validation
# ============================================================================

# @name API_Options_200
# Description: Test OPTIONS method on an API endpoint (CORS preflight)
OPTIONS {{baseUrl}}/api/auth/register

###

# @name API_GET_Missing_Accept_406
# Description: Test GET request missing the Accept: application/json header
GET {{baseUrl}}/api/auth/me
Accept: text/plain

###

# @name API_POST_Missing_ContentType_406
# Description: Test POST request missing the Content-Type: application/json header
POST {{baseUrl}}/api/auth/register
Content-Type: text/plain

{
    "username": "testUser_api"
}

###

# @name API_PATCH_Missing_ContentType_406
# Description: Test PATCH request missing the Content-Type: application/json header
PATCH {{baseUrl}}/api/auth/edit
Content-Type: text/plain

{
    "username": "updatedUser_api"
}

###

# ============================================================================
# GROUP: Auth - Register
# ============================================================================

# @name Register_Success_201
# Description: Test successful registration of a new user
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "testUser_api",
    "email": "test_api@example.com",
    "password": "password123"
}

###

# @name Register_Missing_Data_400
# Description: Test error handling when required keys are missing
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "incompleteUser"
}

###

# @name Register_Conflict_409
# Description: Test error handling when email or username is already in use
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "testUser_api",
    "email": "test_api@example.com",
    "password": "password123"
}

###

# ============================================================================
# GROUP: Auth - Login
# ============================================================================

# @name Login_Success_200
# Description: Test successful login with correct credentials
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "identifier": "testUser_api",
    "password": "password123"
}

###

# @name Login_Wrong_Password_401
# Description: Test login with an incorrect password
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "identifier": "testUser_api",
    "password": "wrongPassword"
}

###

# @name Login_User_Not_Found_401
# Description: Test login with an unregistered identifier
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "identifier": "nonexistent_api_user",
    "password": "password123"
}

###

# ============================================================================
# GROUP: Auth - Logout
# ============================================================================

# @name Logout_Success_204
# Description: Test successful logout.
# This test relies on a preceding successful login (like Login_Success_200)
# to have established a valid session cookie.
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

###

# @name Logout_Unauthorized_401
# Description: Test that attempting to logout without a valid session
# (e.g., after a successful logout) results in an unauthorized error.
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

###

# ============================================================================
# GROUP: Auth - Me
# ============================================================================

# @name Get_Me_Success_200
# Description: Test successful retrieval of the current authenticated user's data.
# Ensure you run a successful login request before running this test.
GET {{baseUrl}}/api/auth/me
Accept: application/json

###

# @name Get_Me_Unauthorized_401
# Description: Test error handling when attempting to retrieve user data without being logged in.
# Ensure you run a logout request (or clear your cookies) before running this test.
GET {{baseUrl}}/api/auth/me
Accept: application/json

###

# ============================================================================
# GROUP: Auth - Edit
# ============================================================================

# @name Edit_Success_204
# Description: Test successful update of user profile.
# Ensure you run a successful login request before running this test.
PATCH {{baseUrl}}/api/auth/edit
Content-Type: application/json

{
    "username": "updatedUser_api",
    "email": "updated_api@example.com"
}

###

# @name Edit_Missing_Data_400
# Description: Test error handling when attempting to edit without providing any data.
# Ensure you run a successful login request before running this test.
PATCH {{baseUrl}}/api/auth/edit
Content-Type: application/json

{"sessionId": "LetMeInPlease"}

###

# @name Edit_Conflict_409
# Description: Test error handling when updating to an email or username already in use.
# Ensure you run a successful login request before running this test.
# Note: "PirateKing" is a pre-existing username from users.json.
PATCH {{baseUrl}}/api/auth/edit
Content-Type: application/json

{
    "username": "Samtopia"
}

###

# @name Edit_Unauthorized_401
# Description: Test error handling when attempting to edit user data without being logged in.
# Ensure you run a logout request (or clear your cookies) before running this test.
PATCH {{baseUrl}}/api/auth/edit
Content-Type: application/json

{
    "username": "hackerUser"
}

###

# ============================================================================
# GROUP: Auth - Delete
# ============================================================================

# @name Delete_Success_204
# Description: Test successful deletion of the current authenticated user.
# Ensure you run a successful login request before running this test.
DELETE {{baseUrl}}/api/auth/delete

###

# @name Delete_Unauthorized_401
# Description: Test error handling when attempting to delete a user without being logged in.
# Ensure you run a logout request (or clear your cookies) before running this test.
DELETE {{baseUrl}}/api/auth/delete

###

