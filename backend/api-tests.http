GET {{baseUrl}}/api/users
Accept: application/json

###

# @name Get_Users_Unauthorized_401
# Description: Test error handling when attempting to retrieve users without being logged in.
# Ensure you run a logout request (or clear your cookies) before running this test.
GET {{baseUrl}}/api/users
Accept: application/json

